# Copy this file to .env and fill in the values.
# Run the setup scripts to configure interactively:
#   pnpm db-setup          → set DATABASE_URL
#   pnpm smtp-setup        → configure email delivery
#   pnpm generate-secret   → generate ADMIN_SECRET
#   pnpm whitelist-add     → add permitted admin emails
#   pnpm reset-admin       → clear admin accounts (re-run /admin/setup)

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/scavenger_hunt?schema=public"

# ── Admin authentication ──────────────────────────────────────────────────────
# Signs session tokens — generate with: pnpm generate-secret
ADMIN_SECRET="replace-this-with-a-long-random-secret-string"

# ── SMTP (admin 2FA email) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# ── Admin enrolment whitelist ─────────────────────────────────────────────────
# Comma-separated list of emails permitted to create an admin account.
# If unset, any email can enrol via /admin/setup.
# ADMIN_ALLOWED_EMAILS=you@example.com,colleague@example.com
